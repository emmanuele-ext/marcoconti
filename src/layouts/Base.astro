---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Le cose che mi ha insegnato Marco Conti' } = Astro.props;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main" class="skip-link">Vai al contenuto</a>

    <header class="site-header">
      <div class="container">
        <a href="/" class="site-logo" aria-label="Home">
          Le cose che mi ha insegnato
          <span class="logo-name">Marco Conti</span>
        </a>
      </div>
    </header>

    <main id="main" class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>Cose che si imparano una volta sola.</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    padding: var(--space-2) var(--space-4);
    background: var(--color-text);
    color: var(--color-surface);
    font-size: var(--text-sm);
    text-decoration: none;
    z-index: 100;
    transition: top 0.2s;
  }

  .skip-link:focus-visible {
    top: 0;
  }

  .container {
    max-width: 760px;
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  .site-header {
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-8);
    margin-bottom: var(--space-8);
  }

  .site-logo {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .logo-name {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-top: 6px;
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-8);
    padding-block: var(--space-8);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-align: center;
  }
</style>
