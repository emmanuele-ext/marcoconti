---
import { getCollection, getEntry, render } from 'astro:content';
import Base from '../layouts/Base.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((article) => ({ params: { slug: article.id } }));
}

const { slug } = Astro.params;
const article = await getEntry('articles', slug!);

if (!article) return Astro.redirect('/');

const { Content } = await render(article);

const fmt = new Intl.DateTimeFormat('it-IT', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={article.data.title} description={article.data.description}>
  <article class="article">
    <header class="article-header">
      <h1 class="article-title">{article.data.title}</h1>
      <time class="article-date" datetime={article.data.date.toISOString()}>
        {fmt.format(article.data.date)}
      </time>
      {article.data.description && (
        <p class="article-description">{article.data.description}</p>
      )}
    </header>

    <div class="article-body">
      <Content />
    </div>

    <footer class="article-footer">
      <a href="/" class="back-link">← Torna all'elenco</a>
    </footer>
  </article>
</Base>

<style>
  .article-header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .article-date {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  .article-title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, var(--text-3xl));
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: var(--space-6);
  }

  .article-description {
    font-size: var(--text-lg);
    font-weight: 200;
    color: var(--color-muted);
    letter-spacing: 0.02em;
    border-left: 1px solid var(--color-border);
    padding-left: var(--space-6);
  }

  /* prose */
  .article-body {
    font-size: var(--text-base);
    font-weight: 300;
    line-height: 1.9;
    letter-spacing: 0.01em;
  }

  .article-body :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }

  .article-body :global(h3) {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }

  .article-body :global(p) {
    margin-bottom: var(--space-6);
  }

  .article-body :global(blockquote) {
    border-left: 1px solid var(--color-border);
    padding-left: var(--space-6);
    color: var(--color-muted);
    font-weight: 200;
    font-size: var(--text-lg);
    margin-block: var(--space-8);
  }

  .article-body :global(code) {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    background: #111;
    padding: 2px var(--space-2);
  }

  .article-body :global(pre) {
    background: #0A0A0A;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    padding: var(--space-6);
    overflow-x: auto;
    margin-block: var(--space-6);
  }

  .article-body :global(pre code) {
    background: none;
    padding: 0;
    font-size: var(--text-sm);
  }

  .article-footer {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .back-link:hover,
  .back-link:focus-visible {
    color: var(--color-text);
  }
</style>
